{
  "compilerOptions": {
    "jsx": "react-jsx",
    "outDir": "./dist",
    "module": "ESNext",
    "moduleResolution": "Node",
    "target": "ES6",
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*", "backend/**/*"],
  "exclude": ["node_modules"]
}
